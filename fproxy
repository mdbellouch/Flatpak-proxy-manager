# --- ANSI COLORS ---
G = '\033[92m'  # Green
Y = '\033[93m'  # Yellow
R = '\033[91m'  # Red
C = '\033[96m'  # Cyan
B = '\033[1m'   # Bold
E = '\033[0m'   # End

DEFAULT_PROXY = "http://10.187.197.92:7071"

def run_cmd(cmd):
    return subprocess.run(cmd, capture_output=True, text=True)

def get_installed_apps():
    result = run_cmd(["flatpak", "list", "--app", "--columns=application,name"])
    return [line.split('\t') for line in result.stdout.strip().split('\n') if line.strip()]

def get_proxy_status(app_id=None):
    cmd = ["flatpak", "override", "--user", "--show"]
    if app_id:
        cmd.append(app_id)
    result = run_cmd(cmd)
    if "http_proxy=" in result.stdout or "https_proxy=" in result.stdout:
        for line in result.stdout.split('\n'):
            if "http_proxy=" in line:
                return line.split('=')[1]
    return None

def set_proxy(app_id, proxy_url):
    run_cmd(["flatpak", "override", "--user", f"--env=http_proxy={proxy_url}", app_id])
    run_cmd(["flatpak", "override", "--user", f"--env=https_proxy={proxy_url}", app_id])
    run_cmd(["flatpak", "override", "--user", f"--env=ftp_proxy={proxy_url}", app_id])
    run_cmd(["flatpak", "override", "--user", f"--env=all_proxy={proxy_url}", app_id])

def clear_proxy(app_id=None):
    vars_to_clear = ["http_proxy", "https_proxy", "ftp_proxy", "all_proxy"]
    for var in vars_to_clear:
        args = ["flatpak", "override", "--user", f"--unset-env={var}"]
        if app_id:
            args.append(app_id)
        run_cmd(args)

